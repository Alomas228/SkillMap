@model SkillMap.Models.LoginViewModel

@{
    ViewData["Title"] = "Вход в SkillMap";
}

<div class="login-container">
    <div class="login-card">
        <img src="/images/logo.svg" alt="SkillMap" class="logo" />

        <form asp-action="Login" method="post">
            <!-- Область для вывода общих ошибок -->
            
            
            <div class="form-group">
                <input asp-for="Email" class="form-control" placeholder="Корпоративная почта" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <input asp-for="Password" class="form-control" placeholder="Пароль" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="error-message" role="alert"></div>

            <button type="submit" class="btn-login">Войти</button>
        </form>

        <button class="btn-google" onclick="alert('Интеграция с Google Workspace')">
            Войти через Google Workspace
        </button>

        <div class="login-footer">
            <a href="@Url.Action("ForgotPassword")">Забыли пароль?</a>
            <span>|</span>
            <span>Нет аккаунта? Обратитесь к HR</span>
        </div>
    </div>
</div>

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        background: #f5f7fa;
    }

    .login-card {
        background: white;
        padding: 40px;
        border-radius: 20px;
        width: 380px;
        text-align: center;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }

    .logo {
        width: 160px;
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 15px;
        text-align: left;
    }

    .form-control {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 10px;
        font-size: 14px;
    }

    .form-control:focus {
        outline: none;
        border-color: #2c7da0;
        box-shadow: 0 0 0 3px rgba(44,125,160,0.1);
    }

    .btn-login {
        width: 100%;
        padding: 12px;
        background: #2c7da0;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        margin-top: 10px;
        cursor: pointer;
        font-size: 16px;
    }

    .btn-login:hover {
        background: #1f5e7a;
    }

    .btn-google {
        width: 100%;
        padding: 12px;
        background: white;
        border: 1px solid #ddd;
        border-radius: 10px;
        margin-top: 12px;
        cursor: pointer;
        font-size: 14px;
    }

    .btn-google:hover {
        background: #f5f5f5;
    }

    .login-footer {
        margin-top: 25px;
        font-size: 13px;
        color: #666;
    }

    .login-footer a {
        color: #2c7da0;
        text-decoration: none;
    }

    .login-footer a:hover {
        text-decoration: underline;
    }

    /* Стили для ошибок */
    .error-message {
        background: #fee2e2;
        border: 1px solid #fecaca;
        color: #dc2626;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 14px;
        text-align: left;
    }

    .field-error {
        color: #dc2626;
        font-size: 12px;
        display: block;
        margin-top: 5px;
    }

    .validation-summary-errors ul {
        margin: 0;
        padding-left: 20px;
    }
</style>