@model SkillMap.Models.LoginViewModel

@{
    ViewData["Title"] = "Вход в SkillMap";
}

<div class="login-container">
    <div class="login-card">
        <img src="/images/logo.svg" alt="SkillMap" class="logo" />

        <form asp-action="Login" method="post">
            <div class="form-group">
                <input asp-for="Email" class="form-control" placeholder="Корпоративная почта" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input asp-for="Password" class="form-control" placeholder="Пароль" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-login">Войти</button>
        </form>

        <button class="btn-google" onclick="alert('Интеграция с Google Workspace')">
            Войти через Google Workspace
        </button>

        <div class="login-footer">
            <a href="@Url.Action(" ForgotPassword")">Забыли пароль?</a>
            <span>|</span>
            <span>Нет аккаунта? Обратитесь к HR</span>
        </div>
    </div>
</div>

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        background: #f5f7fa;
    }

    .login-card {
        background: white;
        padding: 40px;
        border-radius: 20px;
        width: 380px;
        text-align: center;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }

    .logo {
        width: 160px;
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-control {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 10px;
    }

    .btn-login {
        width: 100%;
        padding: 12px;
        background: #2c7da0;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        margin-top: 10px;
        cursor: pointer;
    }

    .btn-google {
        width: 100%;
        padding: 12px;
        background: white;
        border: 1px solid #ddd;
        border-radius: 10px;
        margin-top: 12px;
        cursor: pointer;
    }

    .login-footer {
        margin-top: 25px;
        font-size: 13px;
        color: #666;
    }

        .login-footer a {
            color: #2c7da0;
            text-decoration: none;
        }
</style>