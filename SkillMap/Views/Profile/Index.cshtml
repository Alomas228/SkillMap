@{
    ViewData["Title"] = "Мой профиль";
}

<h1>Профиль пользователя</h1>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@ViewBag.UserName</h5>
        <p class="card-text">
            <strong>Email:</strong> @ViewBag.UserEmail<br />
            <strong>Роль:</strong> @ViewBag.UserRole<br />
            <strong>Отдел:</strong> @ViewBag.Department<br />
            <strong>Должность:</strong> @ViewBag.Position
        </p>
    </div>
</div>