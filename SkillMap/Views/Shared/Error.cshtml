@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="error-container">
    <h1>😕 Упс! Что-то пошло не так</h1>
    
    <div class="error-card">
        @if (Model.ShowRequestId)
        {
            <p><strong>Request ID:</strong> @Model.RequestId</p>
        }
        
        <p>Пожалуйста, попробуйте позже или обратитесь к администратору.</p>
        
        @if (User.Identity.IsAuthenticated)
        {
            <a href="/Home/Index" class="btn-home">Вернуться на главную</a>
        }
        else
        {
            <a href="/Account/Login" class="btn-home">Вернуться на страницу входа</a>
        }
    </div>
</div>

<style>
    .error-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 20px;
    }
    
    .error-card {
        background: white;
        padding: 40px;
        border-radius: 20px;
        text-align: center;
        max-width: 500px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    
    h1 {
        font-size: 48px;
        margin-bottom: 20px;
        color: #dc2626;
    }
    
    .btn-home {
        display: inline-block;
        margin-top: 20px;
        padding: 12px 24px;
        background: #2c7da0;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        transition: background 0.2s;
    }
    
        .btn-home:hover {
            background: #1f5e7a;
        }
</style>